#include <iostream>
#include <climits>
using namespace std;

int main() {
    int arr[] = {5,2,8,1,3};
    int n = 5;

    int largest = INT_MIN, second = INT_MIN;

    for(int i=0;i<n;i++) {
        if(arr[i] > largest) {
            second = largest;
            largest = arr[i];
        }
        else if(arr[i] > second && arr[i] != largest) {
            second = arr[i];
        }
    }

    cout<<"Second Largest: "<<second;
}
