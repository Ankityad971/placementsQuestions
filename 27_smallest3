#include <iostream>
#include <climits>
using namespace std;

int main() {
    int arr[] = {5,2,8,1,3};
    int n = 5;

    int a=INT_MAX,b=INT_MAX,c=INT_MAX;

    for(int i=0;i<n;i++) {
        if(arr[i]<a) {
            c=b; b=a; a=arr[i];
        }
        else if(arr[i]<b) {
            c=b; b=arr[i];
        }
        else if(arr[i]<c) {
            c=arr[i];
        }
    }

    cout<<a<<" "<<b<<" "<<c;
}
