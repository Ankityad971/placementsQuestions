#include <iostream>
using namespace std;

int main() {
    int arr[] = {1,2,1,3,4,2,3};
    int n = 7;

    int maxLen = 0;

    for(int i=0;i<n;i++) {
        bool visited[100] = {false};
        int len = 0;

        for(int j=i;j<n;j++) {
            if(visited[arr[j]]) break;
            visited[arr[j]] = true;
            len++;
        }

        if(len > maxLen) maxLen = len;
    }

    cout<<maxLen;
}
