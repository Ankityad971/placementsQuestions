#include <iostream>
using namespace std;

int main() {
    int arr[] = {1,2,2,3,3,3};
    int n = 6;

    for(int i=0;i<n;i++) {
        int count = 0;
        bool visited = false;

        for(int k=0;k<i;k++)
            if(arr[i] == arr[k]) visited = true;

        if(visited) continue;

        for(int j=0;j<n;j++)
            if(arr[i] == arr[j]) count++;

        cout<<arr[i]<<" -> "<<count<<endl;
    }
}











#include <iostream>
#include <unordered_map>
using namespace std;

int main() {
    int arr[] = {1, 2, 2, 3, 3, 3};
    int n = 6;

    unordered_map<int, int> freq;

    // Count frequency
    for(int i = 0; i < n; i++) {
        freq[arr[i]]++;
    }

    // Print frequency
    for(auto it : freq) {
        cout << it.first << " -> " << it.second << endl;
    }

    return 0;
}
