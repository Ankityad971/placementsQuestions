#include <iostream>
using namespace std;

int main() {
    int arr[] = {1,2,2,3,4,4};
    int n = 6;

    for(int i=0;i<n;i++) {
        bool duplicate = false;
        for(int j=0;j<i;j++) {
            if(arr[i] == arr[j]) {
                duplicate = true;
                break;
            }
        }
        if(!duplicate) cout<<arr[i]<<" ";
    }
}
