#include <iostream>
using namespace std;

int main() {
    int arr[] = {-2,1,-3,4,-1,2,1,-5,4};
    int n = 9;

    int maxSum = arr[0], curr = arr[0];

    for(int i=1;i<n;i++) {
        if(curr + arr[i] > arr[i])
            curr = curr + arr[i];
        else
            curr = arr[i];

        if(curr > maxSum)
            maxSum = curr;
    }

    cout<<maxSum;
}
